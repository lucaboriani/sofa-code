---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import RoomCard from '@/components/RoomCard.astro';

const all = await getCollection('rooms');
const sorted = all.sort((a: CollectionEntry<'rooms'>, b: CollectionEntry<'rooms'>) => a.data.order - b.data.order);

const spanFor = (i: number): 'wide' | 'narrow' | 'third' => {
  if (i === 0) return 'wide';
  if (i === 1) return 'narrow';
  return 'third';
};
---
<BaseLayout title="SOFA/WORKS — Gallery" active="home">
  <Hero />
  <div class="quip-bar">
    <span class="quip-label">Filter:</span>
    <span class="quip-text">404 productivity not found</span>
  </div>
  <section class="projects">
    {sorted.map((entry: CollectionEntry<'rooms'>, i: number) => (
      <RoomCard
        slug={entry.data.slug}
        num={String(i + 1).padStart(2, '0')}
        title={entry.data.title}
        description={entry.data.description}
        tags={entry.data.tags}
        year={entry.data.year}
        accent={entry.data.accent}
        span={spanFor(i)}
      />
    ))}
  </section>
  <script>
    import '@/scripts/room-preview.ts';
  </script>
</BaseLayout>
<style>
  .quip-bar {
    position: relative; z-index: 1;
    padding: 0 clamp(20px, 5vw, 48px) 40px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
  }
  .quip-label { color: var(--text-dim); }
  .quip-text { color: var(--accent); }
</style>

---
import { ClientRouter } from 'astro:transitions';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
import '@/styles/tokens.css';
import '@/styles/global.css';
import '@/styles/gallery.css';

interface Props {
  title: string;
  active?: 'home' | 'about';
  chrome?: 'site' | 'minimal';
}
const { title, active = 'home', chrome = 'site' } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="icon" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Mono:ital,wght@0,300;0,400;1,300&display=swap" rel="stylesheet" />
  <ClientRouter />
  <script is:inline>
    // ClientRouter wraps each navigation in document.startViewTransition. When
    // a new navigation aborts an in-flight transition, the previous one's
    // Promise rejects with InvalidStateError. The rejection is harmless but
    // shows up in the console — swallow only this specific case.
    if (!window.__sofaVtRejectionFilter) {
      window.__sofaVtRejectionFilter = true;
      window.addEventListener('unhandledrejection', e => {
        const r = e.reason;
        if (r && r.name === 'InvalidStateError' && /Transition was aborted/i.test(r.message || '')) {
          e.preventDefault();
        }
      });
    }
  </script>
  <script>
    import { getAudioBus } from '@/lib/audio/bus';
    import { wireTransitions } from '@/lib/transitions/wiring';

    const bus = getAudioBus();

    const resolveSlug = (): string | null => {
      const m = location.pathname.match(/^\/rooms\/([a-z-]+)/);
      return m ? m[1] : null;
    };

    const resolveHasAudio = (slug: string): boolean => {
      const el = document.querySelector<HTMLCanvasElement>(`[data-room-stage="${slug}"]`);
      return el?.dataset.hasAudio === 'true';
    };

    const detachKey = '__sofaTransitionsDetach__';
    const w = window as unknown as Window & { [k: string]: unknown };
    const prev = w[detachKey];
    if (typeof prev === 'function') (prev as () => void)();
    w[detachKey] = wireTransitions(bus, resolveSlug, resolveHasAudio);
  </script>
</head>
<body class={chrome === 'minimal' ? 'room-body' : undefined}>
  {chrome === 'site' && <Nav active={active} />}
  <slot />
  {chrome === 'site' && <Footer />}
</body>
</html>

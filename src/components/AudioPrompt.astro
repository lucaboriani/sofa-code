---
interface Props { slug: 'neural' | 'tunnel' | 'swarm'; }
const { slug } = Astro.props;
---
<button
  type="button"
  class="audio-prompt"
  data-audio-prompt={slug}
  aria-label="Enable audio"
>
  <span class="audio-prompt-icon" aria-hidden="true">♪</span>
  <span class="audio-prompt-label">Enable audio</span>
</button>
<style>
  .audio-prompt {
    position: fixed;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    z-index: 6;
    display: inline-flex;
    align-items: center;
    gap: 16px;
    font-family: var(--mono);
    font-size: clamp(14px, 2.2vw, 20px);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--text);
    background: rgba(8, 11, 16, 0.72);
    backdrop-filter: blur(12px);
    border: 1px solid var(--border-bright);
    padding: 20px 36px;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s, background 0.2s, transform 0.2s;
  }
  .audio-prompt:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: rgba(8, 11, 16, 0.88);
    transform: translate(-50%, -50%) scale(1.03);
  }
  .audio-prompt.is-dismissed { display: none; }
  .audio-prompt-icon { font-size: 1.4em; line-height: 1; }
</style>

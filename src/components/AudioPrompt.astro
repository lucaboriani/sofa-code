---
interface Props { slug: 'neural' | 'tunnel' | 'swarm'; }
const { slug } = Astro.props;
---
<button
  type="button"
  class="audio-prompt"
  data-audio-prompt={slug}
  aria-label="Enable audio"
>
  <span class="audio-prompt-icon" aria-hidden="true">♪</span>
  <span class="audio-prompt-label">Enable audio</span>
</button>
<style>
  .audio-prompt {
    position: fixed;
    left: 24px;
    bottom: 24px;
    z-index: 6;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-mid);
    background: rgba(8, 11, 16, 0.6);
    backdrop-filter: blur(8px);
    border: 1px solid var(--border);
    padding: 8px 14px 8px 12px;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }
  .audio-prompt:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: rgba(8, 11, 16, 0.78);
  }
  .audio-prompt.is-dismissed { display: none; }
  .audio-prompt-icon { font-size: 14px; line-height: 1; }
</style>

---
import type { RoomSlug } from '@/lib/rooms/registry';
interface Props { slug: RoomSlug; hasAudio: boolean; }
const { slug, hasAudio } = Astro.props;
---
<canvas
  class="room-stage"
  data-room-stage={slug}
  data-has-audio={String(hasAudio)}
  transition:name={`room-canvas-${slug}`}
></canvas>
<style>
  .room-stage {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    display: block;
    z-index: 0;
    background: #000;
    /* The room drives its own two-finger pinch via pointer events — stop the
       browser from hijacking touches to pan/zoom the page instead. */
    touch-action: none;
    /* Rooms with a press-and-hold interaction (e.g. cyberspace's tap-to-lock)
       otherwise trigger iOS Safari's long-press callout (Save Image/Copy) on
       the canvas — see contextmenu prevention in room-stage.ts for the rest
       of this (Android/desktop use the contextmenu event, not this). */
    -webkit-touch-callout: none;
  }
</style>
